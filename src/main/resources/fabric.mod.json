{
  "schemaVersion": 1,
  "id": "centuryrafflehelper",
  "version": "${version}",
  "name": "Century Raffle Helper",
  "icon": "icon.png",
  "description": "CRH helps you maximize your profits with the Skyblock Hypixel Century Raffle and shows HUD timers, tickets, cake slices, and daily tasks for the Hypixel SkyBlock Century Raffle.",
  "authors": ["AbruptSteve"],
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.abruptsteve.centuryrafflehelper.CenturyRaffleHelperMod"
    ],
    "modmenu": [
      "dev.abruptsteve.centuryrafflehelper.compat.ModMenuIntegration"
    ]
  },
  "mixins": [
    "crh.mixins.json"
  ],
  "depends": {
    "fabric-api": ">=${fabric_api_version}",
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${minecraft_version}"
  },
  "suggests": {
    "modmenu": ">=${modmenu_version}"
  }
}
